# .env.prod.example – Docker production environment variables
#
# Copy to .env.prod and fill in the values before running:
#   docker compose --env-file .env.prod up --build -d
#
# Differences from plain .env:
#   - DATABASE_URL uses "db" as the hostname (Docker service name, not localhost)
#   - DB_USER / DB_PASSWORD are used by docker-compose.yml to create the Postgres user
#   - BACKEND_CORS_ORIGINS must include the real public domain
#   - APP_VERSION pins which GitHub release tag to build from (e.g. v1.2.0)

# ---------------------------------------------------------------------------
# Release version — GitHub tag to build all services from
# ---------------------------------------------------------------------------
APP_VERSION=v1.0.0

# ---------------------------------------------------------------------------
# Docker-compose DB bootstrap (used by the `db` service in docker-compose.yml)
# ---------------------------------------------------------------------------
DB_USER=raildashboard
DB_PASSWORD=change-me-in-production

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# Postgres connection — assembled automatically from DB_USER + DB_PASSWORD in docker-compose.yml.
# Do NOT set DATABASE_URL manually here; it would override the auto-assembled value.

# CORS — list the public URL(s) that the browser will use to reach the app
# BACKEND_CORS_ORIGINS=["https://your-domain.com"]

# ERA RINF API (optional — only needed for RINF data imports)
RINF_API_URL=https://rinf.era.europa.eu/api
RINF_USERNAME=
RINF_PASSWORD=

# Routing microservice — uses the "graphhopper" Docker service name (not localhost).
# Increment GRAPH_VERSION whenever you deploy a new OSM extract to bust the route cache.
ROUTING_BASE_URL=http://graphhopper:8989
ROUTING_TIMEOUT_SECONDS=20
GRAPH_VERSION=1

# OSM PBF extract URL — GraphHopper downloads this automatically on first start if the
# graph cache volume (ghdata) is empty. Leave blank to skip GraphHopper.
# Source: https://download.geofabrik.de/
# Germany (~4 GB): https://download.geofabrik.de/europe/germany-latest.osm.pbf
GH_OSM_URL=

# Celery task queue — hostname is the Docker service name "redis" (internal Docker network, not exposed to host)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM API for optional AI extraction (VIB import and future features).
# Supports any OpenAI-compatible endpoint: OpenAI, Ollama, Azure OpenAI, Mistral, etc.
# Leave LLM_BASE_URL empty to disable AI extraction entirely.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Frontend (baked into the JS bundle at docker compose build time)
# ---------------------------------------------------------------------------

# Empty → API calls use a relative path (/api/...) and nginx proxies them to the backend.
# Set this to the full public URL only if you are NOT routing through nginx
# (e.g. VITE_API_BASE_URL=https://api.your-domain.com).
VITE_API_BASE_URL=

# Raster tile layer URL for the map
REACT_APP_TILE_LAYER_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
