# Schienendashboard – environment variable reference
#
# Copy this file to .env (repo root) and fill in the values.
# Lines starting with # are comments and are not loaded.
#
# Both backend and frontend read from this single file.
# Frontend variables must be prefixed with VITE_ to be embedded at build time.

# ---------------------------------------------------------------------------
# Backend (apps/backend/.env)
# ---------------------------------------------------------------------------

# PostgreSQL connection string with PostGIS extension.
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=URL

# ERA RINF API credentials
RINF_API_URL=https://rinf.era.europa.eu/api
RINF_USERNAME=
RINF_PASSWORD=

# Routing microservice (GraphHopper).
# For local dev, start with: docker compose -f docker-compose.dev.yml --profile routing up -d
# GraphHopper then listens on localhost:8989 (see docker/graphhopper/config.yml).
ROUTING_BASE_URL=http://localhost:8989
# Timeout in seconds for requests to the routing microservice (default: 20)
ROUTING_TIMEOUT_SECONDS=20
# Increment whenever you deploy a new OSM extract; busts the route cache.
GRAPH_VERSION=1

# Allowed CORS origins for the backend (JSON array string).
# Default: ["http://localhost:5173"]. Override for production.
# BACKEND_CORS_ORIGINS=["http://localhost:5173","https://your-domain.com"]

# Celery task queue (requires Redis)
# Dev: Redis runs in Docker via docker-compose.dev.yml (port 6379)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM API for optional AI extraction (VIB import and future features).
# Supports any OpenAI-compatible endpoint: OpenAI, Ollama, Azure OpenAI, Mistral, etc.
# Leave LLM_BASE_URL empty to disable AI extraction entirely.
# Examples:
#   OpenAI:  LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
#   Ollama:  LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=llama3  LLM_API_KEY=ollama
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional: load an alternative .env file for a specific environment
# Example: ENVIRONMENT=test  →  loads .env.test instead
# ENVIRONMENT=

# OpenStreetMap offline import settings
# Directory containing <COUNTRY>.osm.pbf extracts (default: data/osm)
# OSM_PBF_DIR=data/osm
# Set to 0 to skip geometry creation during OSM offline imports
# USE_GEOMETRY=1

# ---------------------------------------------------------------------------
# Frontend (apps/frontend/.env)
# ---------------------------------------------------------------------------

# Backend API base URL (default: http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# Raster tile layer URL for the map view
# Example for OpenStreetMap tiles (check tile provider ToS before use):
# REACT_APP_TILE_LAYER_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
REACT_APP_TILE_LAYER_URL=
