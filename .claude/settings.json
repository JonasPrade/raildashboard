          {
            "type": "command",
            "command": "bash /Users/jonas/Documents/coding/raildashboard/.claude/hooks/remind-migration.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/jonas/Documents/coding/raildashboard/.claude/hooks/remind-roadmap.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/jonas/Documents/coding/raildashboard/.claude/hooks/remind-auth.sh"
