# .env.docker-dev.example – adjustments for local development with Docker DB
#
# When using docker-compose.dev.yml, the Postgres DB runs in Docker on port 5433.
# Update your .env (repo root) with the DATABASE_URL below so that the locally
# running backend connects to the Docker DB instead of a local Postgres installation.
#
# All other settings remain unchanged from .env.example.

# Postgres is exposed on host port 5433 (mapped from container port 5432).
DATABASE_URL=postgresql+psycopg2://raildashboard:raildashboard@localhost:5433/raildashboard

# Frontend dev server still talks directly to the local backend
VITE_API_BASE_URL=http://localhost:8000
